{
  "name": "create-groot",
  "version": "0.0.0",
  "description": "🌱 Plant a bun-first Turborepo and grow it: web, mobile, API and Convex backend from one command.",
  "keywords": [
    "bun",
    "turborepo",
    "monorepo",
    "scaffold",
    "cli",
    "create",
    "nextjs",
    "sveltekit",
    "expo",
    "elysia",
    "hono",
    "convex"
  ],
  "homepage": "https://github.com/bloxy-studios/groot#readme",
  "bugs": "https://github.com/bloxy-studios/groot/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloxy-studios/groot.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Bloxy Studios (https://github.com/bloxy-studios)",
  "type": "module",
  "bin": {
    "create-groot": "./bin/groot.mjs",
    "groot": "./bin/groot.mjs"
  },
  "files": [
    "bin",
    "src",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --minify --sourcemap src/index.ts --outfile dist/groot",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
