{
  "name": "groot-workspace",
  "private": true,
  "description": "Monorepo for groot — the bun-first Turborepo scaffolder (published package: create-groot)",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
